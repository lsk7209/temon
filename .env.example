# Database (Turso)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# App
NEXT_PUBLIC_APP_URL=https://temon.kr

# Admin
ADMIN_TOKEN=

# Cron
CRON_SECRET=
GSC_INDEXING_API_ENABLED=false
SEARCH_SUBMISSION_RETRY_BATCH_SIZE=10
# Maximum recently published rows inspected by the hourly idle retry path (1-100).
SEARCH_SUBMISSION_RETRY_SCAN_LIMIT=50

# Analytics
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_CLARITY_ID=
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-3050601904412736
NEXT_PUBLIC_ADSENSE_CLIENT_ID=

# SEO
# IndexNow: public/ 디렉토리에 {KEY}.txt 파일명과 동일하게 설정
# 현재 파일: public/186d3c7ad0df4ce9ae53deb59055ed23.txt
INDEXNOW_KEY=186d3c7ad0df4ce9ae53deb59055ed23
# Google Search Console: 메타태그 방식 → GSC > 설정 > 소유권 확인 > HTML 태그의 content 값
GOOGLE_SITE_VERIFICATION=
# 새 글 발행 시 GSC sitemap 제출 + Google Indexing API 알림에 사용
# Vercel에는 JSON 전체를 GOOGLE_SERVICE_ACCOUNT_JSON 또는 base64로 넣는 방식을 권장
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_SERVICE_ACCOUNT_PATH=
GSC_SITE_URL=sc-domain:temon.kr
GSC_PROPERTY_URL=sc-domain:temon.kr
GSC_SITEMAP_URL=https://temon.kr/sitemap.xml
# 네이버 서치어드바이저: https://searchadvisor.naver.com > 사이트 등록 > HTML 태그 content 값
NAVER_SITE_VERIFICATION=
DAUM_SITE_VERIFICATION=

# AI (for test generation)
GOOGLE_GENERATIVE_AI_KEY=
