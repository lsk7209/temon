{
  "functions": {
    "app/api/**/*.ts": { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=3600"
        }
      ]
    },
    {
      "source": "/sitemap-index.xml",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=300, s-maxage=300, stale-while-revalidate=3600"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/generate",
      "schedule": "0 * * * *"
    },
    {
      "path": "/api/cron/publish",
      "schedule": "0 * * * *"
    }
  ]
}
